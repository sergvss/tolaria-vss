#!/bin/sh
# Pre-commit: fast local gate before commit. Full suite runs in pre-push/CI.
set -e

ensure_node_tooling() {
  if command -v node >/dev/null 2>&1 && command -v pnpm >/dev/null 2>&1; then
    return 0
  fi

  NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh" --no-use
    nvm use --silent node >/dev/null 2>&1 || true
  fi

  if ! command -v node >/dev/null 2>&1 || ! command -v pnpm >/dev/null 2>&1; then
    echo "❌ node and pnpm must be available before committing"
    echo "   Install them or make sure your nvm setup is available to git hooks."
    exit 1
  fi
}

require_main_branch() {
  if ! git symbolic-ref -q HEAD >/dev/null 2>&1; then
    echo "❌ Commits must happen on main. Detached HEAD is not allowed."
    exit 1
  fi

  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  if [ "$CURRENT_BRANCH" != "main" ]; then
    echo "❌ Commits must happen on main. Current branch: $CURRENT_BRANCH"
    echo "   Merge or cherry-pick your work onto main, then commit there."
    exit 1
  fi
}

require_main_branch
ensure_node_tooling

echo "🔍 Pre-commit checks..."

# Docs-only short-circuit: every staged file matches *.md or sits under
# docs/. These cannot regress lint/types/tests, so skip the whole gate.
STAGED_ALL=$(git diff --cached --name-only)
NON_DOCS=$(echo "$STAGED_ALL" | grep -vE '(^docs/|\.md$)' || true)
if [ -z "$NON_DOCS" ] && [ -n "$STAGED_ALL" ]; then
  echo "  → docs-only commit, skipping lint/tsc/tests"
  echo "✅ Pre-commit passed"
  exit 0
fi

# Lint + types (only if TS files staged). ESLint is scoped to the staged
# paths so we don't re-lint the whole project on tiny diffs.
STAGED_TS=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' || true)
if [ -n "$STAGED_TS" ]; then
  echo "  → lint + tsc..."
  echo "$STAGED_TS" | xargs pnpm exec eslint --quiet --max-warnings=0
  npx tsc --noEmit
fi

# Unit tests — only if frontend code, frontend deps, or test config changed.
# Pure docs/Rust/CI/scripts/e2e commits cannot regress vitest; the pre-push
# gate still runs the full coverage suite for those, so this only loosens
# the local fast lane.
#
# Only files under `src/` (the React app), the Vite/Vitest configs, and the
# package manifests can affect Vitest. `scripts/` (build helpers like
# fork-build.mjs), `e2e/` and `tests/smoke/` (Playwright suites), and the
# `mcp-server/` package have their own test paths and never run under Vitest.
STAGED_FRONTEND=$(
  git diff --cached --name-only \
    | grep -E '^(src/.*\.(ts|tsx|js|jsx|mjs|cjs)|package\.json|pnpm-lock\.yaml|vite\.config\..*|vitest\.config\..*)$' \
    || true
)
if [ -n "$STAGED_FRONTEND" ]; then
  # Only run tests related to the files being committed. `vitest --changed`
  # uses the dependency graph: it picks the test files that import any
  # changed file (transitively). Fast-fail on the first failure so we
  # don't sit through a full run when one assertion is already broken.
  # Pre-push and CI still cover the rest of the suite.
  echo "  → tests (related to staged changes)..."
  pnpm exec vitest run --silent --changed --bail 1
else
  echo "  → tests skipped (no frontend files staged — pre-push still runs full suite)"
fi

echo "✅ Pre-commit passed"

# Fork change: removed CodeScene step. We do not run a CodeScene project
# for this fork (CODESCENE_PAT / CODESCENE_PROJECT_ID never set), so the
# previous block was a no-op that printed a warning every commit. If we
# ever wire the fork into CodeScene we can resurrect the block from git
# history.
